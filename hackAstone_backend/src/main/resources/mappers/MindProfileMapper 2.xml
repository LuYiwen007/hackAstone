<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.hackastone.base.dal.mapper.MindProfileMapper">

    <resultMap id="BaseResultMap" type="org.hackastone.base.dal.entity.MindProfileEntity">
        <id column="user_id" property="userId" jdbcType="VARCHAR"/>
        <result column="profile_json" property="profileJson" jdbcType="LONGVARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT user_id, profile_json, created_at, updated_at
        FROM ha_mind_profile
        WHERE user_id = #{userId}
    </select>

    <insert id="upsert">
        INSERT INTO ha_mind_profile (user_id, profile_json, created_at, updated_at)
        VALUES (#{userId}, #{profileJson}, NOW(), NOW())
        ON DUPLICATE KEY UPDATE
            profile_json = VALUES(profile_json),
            updated_at = NOW()
    </insert>

</mapper>
