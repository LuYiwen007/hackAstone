<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.hackastone.base.dal.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="org.hackastone.base.dal.entity.UserEntity">
        <id column="id" property="userId" jdbcType="VARCHAR"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="phone" property="phone" jdbcType="VARCHAR"/>
        <result column="password_hash" property="password" jdbcType="VARCHAR"/>
        <result column="nickname" property="nickname" jdbcType="VARCHAR"/>
        <result column="avatar_url" property="avatarUrl" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="ext_info" property="extInfo" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, email, phone, password_hash, nickname, avatar_url, status, ext_info, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="org.hackastone.base.dal.entity.UserEntity">
        INSERT INTO ha_user
        (id, username, email, password_hash, nickname, status, created_at, updated_at)
        VALUES
        (#{userId}, #{username}, #{email}, #{password}, #{nickname}, 'ENABLED', NOW(), NOW())
    </insert>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ha_user
        WHERE username = #{username}
    </select>

    <select id="selectByEmail" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ha_user
        WHERE email = #{email}
    </select>

    <select id="selectByNickname" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ha_user
        WHERE nickname = #{nickname}
    </select>

    <select id="selectByLoginAccount" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ha_user
        WHERE status = 'ENABLED'
          AND (
            email = #{account}
            OR nickname = #{account}
            OR username = #{account}
          )
        LIMIT 1
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ha_user
        WHERE id = #{userId}
    </select>

    <update id="updateExtInfo">
        UPDATE ha_user
        SET ext_info = #{extInfo}, updated_at = NOW()
        WHERE id = #{userId}
    </update>

    <update id="updatePasswordHash">
        UPDATE ha_user
        SET password_hash = #{passwordHash}, updated_at = NOW()
        WHERE id = #{userId}
    </update>

    <update id="updateNickname">
        UPDATE ha_user
        SET nickname = #{nickname}, updated_at = NOW()
        WHERE id = #{userId}
    </update>

    <select id="selectByNicknameExceptUser" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ha_user
        WHERE nickname = #{nickname} AND id != #{userId}
        LIMIT 1
    </select>

</mapper>
