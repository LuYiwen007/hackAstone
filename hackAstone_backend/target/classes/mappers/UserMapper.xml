<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.hackastone.base.dal.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="org.hackastone.base.dal.entity.UserEntity">
        <id column="user_id" property="userId" jdbcType="VARCHAR"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="nickname" property="nickname" jdbcType="VARCHAR"/>
        <result column="role" property="role" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="org.hackastone.base.dal.entity.UserEntity">
        INSERT INTO ha_user_account 
        (user_id, username, password, nickname, role, status, created_at)
        VALUES 
        (#{userId}, #{username}, #{password}, #{nickname}, 'USER', 1, NOW())
    </insert>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT user_id, username, password, nickname, role, status, created_at
        FROM ha_user_account
        WHERE username = #{username}
    </select>

</mapper>