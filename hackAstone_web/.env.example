# 后端 API 地址（与 Spring Boot context-path /api 一致；本地 dev 可留空，走 Vite proxy）
# VITE_API_BASE_URL=http://localhost:8080/api
#
# 后端百炼：若哲学辩论报 AppId invalid，在后端 shell 设置（与 DASHSCOPE_API_KEY 同账号的应用 ID）
# export BAILIAN_ECHO_APP_ID=xxxxxxxx

# 阿里云百炼（DashScope）— AI 生成计划
# 在百炼控制台「密钥管理」创建并复制 API Key
VITE_DASHSCOPE_API_KEY=
# 应用 ID（默认已使用当前应用，如需覆盖可设置）
# VITE_BAILIAN_APP_ID=6f27fb46e69a46f8b003908afe010d84
